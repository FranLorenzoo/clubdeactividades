// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserAppointmentState {
  PAGO_COMPLETO
  PAGO_PARCIAL
  IMPAGO
}

model Role {
  id    Int    @id @default(autoincrement())
  name  String

  users User[]
}

model User {
  id        Int    @id @default(autoincrement())
  email     String @unique
  password  String
  name      String
  lastName  String
  age       Int
  dni       String

  roleId    Int
  role      Role   @relation(fields: [roleId], references: [id])

  client    Client?
  employee  Employee?
  professor Professor?
}

model Client {
  id         Int     @id @default(autoincrement())
  suspended  Boolean
  active     Boolean

  userId     Int     @unique
  user       User    @relation(fields: [userId], references: [id])

  creditCard CreditCard?
  userAppointments UserAppointment[]
}

model CreditCard {
  id            Int    @id @default(autoincrement())
  cardNumber    String
  securityCode  String
  cardHolder    String
  expireDate    DateTime

  clientId      Int    @unique
  client        Client @relation(fields: [clientId], references: [id])
}

model Employee {
  id        Int    @id @default(autoincrement())

  userId    Int    @unique
  user      User   @relation(fields: [userId], references: [id])

  payments  Payment[]
}

model Professor {
  id            Int          @id @default(autoincrement())

  userId        Int          @unique
  user          User         @relation(fields: [userId], references: [id])

  activityId    Int
  activity      Activity     @relation(fields: [activityId], references: [id])

  appointments  Appointment[]
}

model Activity {
  id            Int           @id @default(autoincrement())
  name          String

  professors    Professor[]
  appointments  Appointment[]
}

model Appointment {
  id              Int       @id @default(autoincrement())

  activityId      Int
  activity        Activity  @relation(fields: [activityId], references: [id])

  initialDate     DateTime
  endDate         DateTime

  price           Float

  professorId     Int
  professor       Professor @relation(fields: [professorId], references: [id])

  currentSlots    Int
  slotsAvailable  Int

  userAppointments UserAppointment[]
}

model UserAppointment {
  id               Int                     @id @default(autoincrement())

  appointmentId    Int
  appointment      Appointment             @relation(fields: [appointmentId], references: [id])

  clientId         Int
  client           Client                  @relation(fields: [clientId], references: [id])

  rejected         Boolean

  reservationDate  DateTime

  state            UserAppointmentState

  payments         Payment[]

  qr               QR?

  @@unique([appointmentId, clientId])
}

model Payment {
  id                 Int              @id @default(autoincrement())

  userAppointmentId  Int
  userAppointment    UserAppointment  @relation(fields: [userAppointmentId], references: [id])

  paymentDate        DateTime

  amount             Float

  paymentMethod      String

  employeeId         Int
  employee           Employee         @relation(fields: [employeeId], references: [id])
}

model QR {
  id                 Int              @id @default(autoincrement())

  accepted           Boolean

  userAppointmentId  Int              @unique
  userAppointment    UserAppointment  @relation(fields: [userAppointmentId], references: [id])

  qrImage            String
  url                String
}