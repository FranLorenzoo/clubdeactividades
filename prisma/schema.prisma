// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum userAppointmentState {
  PAGO_COMPLETO
  PAGO_PARCIAL
  IMPAGO
}

model role {
  id    Int    @id @default(autoincrement())
  name  String

  users user[]
}

model user {
  id        Int    @id @default(autoincrement())
  email     String @unique
  password  String
  name      String
  lastName  String
  age       Int
  dni       String

  roleId    Int
  role      role   @relation(fields: [roleId], references: [id])

  client    client?
  employee  employee?
  professor professor?
}

model client {
  id         Int     @id @default(autoincrement())
  suspended  Boolean
  active     Boolean

  userId     Int     @unique
  user       user    @relation(fields: [userId], references: [id])

  creditCard creditCard?
  userAppointments userAppointment[]
}

model creditCard {
  id            Int    @id @default(autoincrement())
  cardNumber    String
  securityCode  String
  cardHolder    String
  expireDate    DateTime

  clientId      Int    @unique
  client        client @relation(fields: [clientId], references: [id])
}

model employee {
  id        Int    @id @default(autoincrement())

  userId    Int    @unique
  user      user   @relation(fields: [userId], references: [id])

  payments  payment[]
}

model professor {
  id            Int          @id @default(autoincrement())

  userId        Int          @unique
  user          user         @relation(fields: [userId], references: [id])

  activityId    Int
  activity      activity     @relation(fields: [activityId], references: [id])

  appointments  appointment[]
}

model activity {
  id            Int           @id @default(autoincrement())
  name          String

  professors    professor[]
  appointments  appointment[]
}

model appointment {
  id              Int       @id @default(autoincrement())

  activityId      Int
  activity        activity  @relation(fields: [activityId], references: [id])

  initialDate     DateTime
  endDate         DateTime

  price           Float

  professorId     Int
  professor       professor @relation(fields: [professorId], references: [id])

  currentSlots    Int
  slotsAvailable  Int

  userAppointments userAppointment[]
}

model userAppointment {
  id               Int                     @id @default(autoincrement())

  appointmentId    Int
  appointment      appointment             @relation(fields: [appointmentId], references: [id])

  clientId         Int
  client           client                  @relation(fields: [clientId], references: [id])

  rejected         Boolean

  reservationDate  DateTime

  state            userAppointmentState

  payments         payment[]

  qr               QR?

  @@unique([appointmentId, clientId])
}

model payment {
  id                 Int              @id @default(autoincrement())

  userAppointmentId  Int
  userAppointment    userAppointment  @relation(fields: [userAppointmentId], references: [id])

  paymentDate        DateTime

  amount             Float

  paymentMethod      String

  employeeId         Int?
  employee           employee?        @relation(fields: [employeeId], references: [id])
}

model QR {
  id                 Int              @id @default(autoincrement())

  accepted           Boolean

  userAppointmentId  Int              @unique
  userAppointment    userAppointment  @relation(fields: [userAppointmentId], references: [id])

  qrImage            String
  url                String
}