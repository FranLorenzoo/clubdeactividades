// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Role {
  id   Int    @id @default(autoincrement())
  name String

  employees Employee[]
}

model User {
  id        Int     @id @default(autoincrement())
  email     String  @unique
  dni       String  @unique
  password  String
  age       Int?
  suspended Boolean @default(false)

  creditCard       CreditCard?
  userAppointments UserAppointment[]
}

model CreditCard {
  id           Int      @id @default(autoincrement())
  cardNumber   String
  securityCode String
  cardHolder   String
  expireDate   DateTime

  userId Int  @unique
  user   User @relation(fields: [userId], references: [id])
}

model Activity {
  id    Int     @id @default(autoincrement())
  name  String
  price Decimal

  appointments Appointment[]
  employees    Employee[]
}

model Employee {
  id        Int     @id @default(autoincrement())
  email     String  @unique
  dni       String  @unique
  password  String
  age       Int?
  suspended Boolean @default(false)

  roleId Int?
  role   Role? @relation(fields: [roleId], references: [id])

  activityId Int
  activity   Activity @relation(fields: [activityId], references: [id])

  payments     Payment[]
  appointments Appointment[]
}

model Appointment {
  id             Int      @id @default(autoincrement())
  initialDate    DateTime
  endDate        DateTime
  currentSlots   Int?
  slotsAvailable Int?

  price Decimal

  activityId Int
  activity   Activity @relation(fields: [activityId], references: [id])

  professorId Int
  professor   Employee @relation(fields: [professorId], references: [id])

  userAppointments UserAppointment[]
}

model UserAppointment {
  id              Int      @id @default(autoincrement())
  type            String?
  attended        Boolean  @default(false)
  reservationDate DateTime @default(now())
  rejected        Boolean  @default(false)

  userId        Int
  appointmentId Int

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  qr       QR?
  payments Payment[]

  @@unique([userId, appointmentId])
}

model Payment {
  id                Int      @id @default(autoincrement())
  userAppointmentId Int
  amount            Decimal
  paymentMethod     PaymentMethod
  paymentDate       DateTime

  employeeId Int?

  employee        Employee?        @relation(fields: [employeeId], references: [id])
  userAppointment UserAppointment @relation(fields: [userAppointmentId], references: [id])
}

model QR {
  id                Int     @id @default(autoincrement())
  used              Boolean @default(false)

  userAppointmentId Int  @unique
  userAppointment   UserAppointment @relation(fields: [userAppointmentId], references: [id], onDelete: Cascade)
}

enum PaymentMethod {
  CASH
  CARD
}